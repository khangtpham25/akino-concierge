# Copy this file to .env and fill in your values
# .env is gitignored — never commit real secrets

# App
ENVIRONMENT=development
DEBUG=true

# Database (matches docker-compose.yml values)
DATABASE_URL=postgresql+asyncpg://hms:hms@localhost:5432/hms

# Redis
REDIS_URL=redis://localhost:6379/0

# Zalo Official Account
# Get these from: https://developers.zalo.me/
ZALO_OA_ID=
ZALO_ACCESS_TOKEN=
ZALO_SECRET_KEY=

# Future OTA integrations (leave blank for now)
# BOOKING_COM_API_KEY=
# AGODA_API_KEY=
